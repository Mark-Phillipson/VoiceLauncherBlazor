@inherits LayoutComponentBase
@using Blazored.Toast.Configuration
@using RazorClassLibrary.Shared
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Hosting
@inject IConfiguration Configuration
@inject IHostEnvironment HostEnv
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<BlazoredToasts Position="ToastPosition.BottomRight" Timeout="5" IconType="IconType.FontAwesome"
    SuccessClass="success-toast-override" SuccessIcon="fa fa-thumbs-up" ErrorIcon="fa fa-bug" ShowProgressBar="true"
    RemoveToastsOnNavigation="true" InfoIcon="fa fa-info" WarningIcon="fa fa-warning" />

<div class="page @CurrentThemeClass">
    <div class="sidebar @(IsSidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
        @if (ShowNavMenu)
        {
            <NavMenu IsDarkTheme='@(CurrentThemeClass == "theme-dark")'
                     ThemeToggleLabel="@ThemeToggleLabel"
                     IsSidebarCollapsed="@IsSidebarCollapsed"
                     OnToggleSidebarCollapse="ToggleSidebarCollapse"
                     OnToggleTheme="ToggleTheme" />
        }
    </div>

    <main class="main">
        <article class="content pe-4 ps-5">
            @Body
        </article>
            </main>
        </div>
        <footer class="center-footer @CurrentThemeClass d-flex justify-content-between align-items-center">
            <div>
                &copy; Voice Admin @DateTime.Now.Year,
                @if (Environment.MachineName == "J40L4V3")
                {
                    <text>Powered by</text>
                    @System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription
                }
            </div>
            <div>
                @if (DemoFooterEnabled)
                {
                    <DemoFooter Text="@DemoFooterText" LinkUrl="@DemoFooterLink" />
                }
            </div>
        </footer>
@* Sync theme class with `data-bs-theme` for attribute-based CSS selectors *@
<script>
(() => {
    try {
        const storageKey = 'appTheme';
        const applyTheme = (theme) => {
            if (!theme) return;
            const t = theme === 'dark' ? 'dark' : 'light';
            try { document.documentElement.setAttribute('data-bs-theme', t); } catch (e) {}
            try { document.body.setAttribute('data-bs-theme', t); } catch (e) {}
        };

        const saved = localStorage.getItem(storageKey);
        applyTheme(saved || 'light');
        console.log('theme-sync initialized with', saved);
        window.addEventListener('storage', (e) => {
            if (e.key === storageKey) applyTheme(e.newValue);
        });

        const obs = new MutationObserver(() => {
            const pageEl = document.querySelector('.page');
            const classList = (pageEl && pageEl.className) || document.documentElement.className || document.body.className || '';
            if (classList.indexOf('theme-dark') !== -1) applyTheme('dark');
            else if (classList.indexOf('theme-light') !== -1) applyTheme('light');
        });
        const target = document.querySelector('.page') || document.body || document.documentElement;
        obs.observe(target, { attributes: true, attributeFilter: ['class'], subtree: true });
    } catch (e) { console.error('theme-sync failed', e); }
})();
</script>
@code {
    private string CurrentThemeClass = "theme-light";
    private bool IsSidebarCollapsed;
    private const string ThemeStorageKey = "appTheme";
    private const string SidebarStorageKey = "appSidebarCollapsed";
    private string ThemeToggleLabel => CurrentThemeClass == "theme-dark" ? "Switch to light mode" : "Switch to dark mode";

    // Demo footer configuration
    private bool DemoFooterEnabled;
    private string DemoFooterText = "This app is a demo hosted on Azure to reduce hosting costs. Functionality, uptime, or data may be limited.";
    private string? DemoFooterLink;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var shouldRefreshUi = false;

            var savedTheme = await JS.InvokeAsync<string>("localStorage.getItem", ThemeStorageKey);
            if (!string.IsNullOrEmpty(savedTheme))
            {
                CurrentThemeClass = savedTheme == "dark" ? "theme-dark" : "theme-light";
                shouldRefreshUi = true;
            }
            else
            {
                CurrentThemeClass = "theme-light";
                await JS.InvokeVoidAsync("localStorage.setItem", ThemeStorageKey, "light");
                await JS.InvokeVoidAsync("localStorage.removeItem", "tvc-theme");
                await JS.InvokeVoidAsync("localStorage.removeItem", "app-theme");
                shouldRefreshUi = true;
            }

            var savedSidebarState = await JS.InvokeAsync<string>("localStorage.getItem", SidebarStorageKey);
            if (!string.IsNullOrEmpty(savedSidebarState))
            {
                IsSidebarCollapsed = savedSidebarState == "1";
                shouldRefreshUi = true;
            }

            if (shouldRefreshUi)
            {
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme()
    {
        CurrentThemeClass = CurrentThemeClass == "theme-dark" ? "theme-light" : "theme-dark";
        await JS.InvokeVoidAsync("localStorage.setItem", ThemeStorageKey, CurrentThemeClass == "theme-dark" ? "dark" : "light");
    }

    private async Task ToggleSidebarCollapse()
    {
        IsSidebarCollapsed = !IsSidebarCollapsed;
        await JS.InvokeVoidAsync("localStorage.setItem", SidebarStorageKey, IsSidebarCollapsed ? "1" : "0");
    }
    private bool ShowNavMenu = true;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        // Ensure NavMenu is shown by default and remove page-specific hiding logic
        ShowNavMenu = true;
        NavigationManager.LocationChanged += HandleLocationChanged;

        // Initialize demo footer settings (Production default unless overridden)
        try
        {
            var cfgEnabled = Configuration.GetValue<bool?>("DemoFooter:Enabled");
            if (cfgEnabled.HasValue)
            {
                DemoFooterEnabled = cfgEnabled.Value;
            }
            else
            {
                DemoFooterEnabled = HostEnv.IsProduction();
            }

            var cfgText = Configuration["DemoFooter:Text"];
            if (!string.IsNullOrEmpty(cfgText))
            {
                DemoFooterText = cfgText;
            }

            DemoFooterLink = Configuration["DemoFooter:LinkUrl"];
        }
        catch
        {
            DemoFooterEnabled = false;
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Ensure NavMenu is shown by default and remove page-specific hiding logic
        ShowNavMenu = true;
        InvokeAsync(StateHasChanged); // Ensure UI updates
    }

    private void ToggleShowNavMenu()
    {
        ShowNavMenu = !ShowNavMenu;
    }

    // Implement IDisposable to unsubscribe from the event
    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}