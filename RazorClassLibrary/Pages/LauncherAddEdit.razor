@page "/launcheradd"
@page "/launcheredit/{Id:int}"
@using SmartComponents
@using Microsoft.AspNetCore.Components.Forms
@using System
@using Microsoft.AspNetCore.Components

<style>
    /* Ensure the checked mark displays correctly across themes for this component */
    .form-check-input:checked {
        background-color: var(--bs-primary, #0d6efd) !important;
        border-color: var(--bs-primary, #0d6efd) !important;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20'%3e%3cpath fill='none' stroke='%23fff' stroke-linecap='round' stroke-linejoin='round' stroke-width='3' d='M6 10l3 3l6-6'/%3e%3c/svg%3e") !important;
        background-repeat: no-repeat !important;
        background-position: center !important;
        background-size: 60% 60% !important;
    }
    /* Larger toggle for eye-tracking */
    .favorite-toggle {
        width: 64px !important;
        height: 64px !important;
        min-width: 64px !important;
        min-height: 64px !important;
        padding: 0 !important;
        border-radius: 8px !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: 1.25rem !important;
    }
    .favorite-toggle i {
        font-size: 1.5rem !important;
        line-height: 1 !important;
    }
    .favorite-label {
        padding-left: 12px;
        font-size: 1.25rem;
        cursor: pointer;
        user-select: none;
    }
</style>

<div style="min-width:80vw">
    <style>
        /* Compact checkbox for dense lists */
        .compact-checkbox {
            width: 22px;
            height: 22px;
            accent-color: var(--bs-primary);
            vertical-align: middle;
            margin-right: 0.5rem;
        }

        /* Make the label an easy hit target without increasing visual density */
        .compact-checkbox-label {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.25rem 0.5rem;
            cursor: pointer;
        }

        /* Fallback for browsers/themes that hide the native check: inline SVG */
        .compact-checkbox[type="checkbox"]:checked {
            background-color: var(--bs-primary);
            border-color: var(--bs-primary);
            color: white;
            background-size: 60% 60%;
            background-position: center;
            background-repeat: no-repeat;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='white'><path d='M13.485 1.929a1 1 0 0 1 0 1.414L6.414 10.414a1 1 0 0 1-1.414 0L2.515 8.93a1 1 0 1 1 1.414-1.414L6 9.586l6.071-6.071a1 1 0 0 1 1.414 0z'/></svg>");
        }

        /* Hide native appearance but keep input accessible; show custom visual box */
        .native-checkbox {
            -webkit-appearance: none;
            appearance: none;
            opacity: 0;
            width: 22px;
            height: 22px;
            margin: 0;
            padding: 0;
            cursor: pointer;
        }

        .compact-checkbox-label .custom-checkbox {
            width: 22px;
            height: 22px;
            display: inline-block;
            border: 1px solid var(--bs-border-color, #ced4da);
            border-radius: 4px;
            background-color: var(--bs-body-bg, transparent);
            box-sizing: border-box;
            flex: 0 0 auto;
        }

        .native-checkbox:checked + .custom-checkbox {
            background-color: var(--bs-primary);
            border-color: var(--bs-primary);
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='white' d='M13.485 1.929a1 1 0 0 1 0 1.414L6.414 10.414a1 1 0 0 1-1.414 0L2.515 8.93a1 1 0 1 1 1.414-1.414L6 9.586l6.071-6.071a1 1 0 0 1 1.414 0z'/%3e%3c/svg%3e");
            background-position: center;
            background-repeat: no-repeat;
            background-size: 60% 60%;
        }

        .native-checkbox:focus + .custom-checkbox {
            box-shadow: 0 0 0 3px rgba(13,110,253,0.12);
            outline: none;
        }
    </style>
    <EditForm Model="@LauncherDTO" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        @if (LauncherDTO.Id > 0)
        {
            <span class="text-info m-1">@LauncherDTO.Id</span>
        }
        <div class="row">
            <div class="col-6">
                <div class="form-group">
                    <label for="Icon">Icon:</label>
                    <div class="d-flex align-items-center mb-2 gap-3">
                        <input type="radio" id="iconList" name="iconMode" checked="@(!UseCustomIconUrl)" @onchange="_ => SetIconInputMode(false)" />
                        <label for="iconList" class="me-2">Select from list</label>
                        <input type="radio" id="iconUrl" name="iconMode" checked="@(UseCustomIconUrl)" @onchange="_ => SetIconInputMode(true)" class="ms-3" />
                        <label for="iconUrl" class="me-2">Enter web address</label>
                        <InputText accesskey="5" class="form-control flex-grow-1" style="max-width: 250px;" placeholder="Type to filter images... (5)" @bind-Value="ImageFilterText" />
                    </div>
                    @if (!UseCustomIconUrl)
                    {
                        <div class="d-flex flex-wrap gap-2 border p-2" style="flex-grow: 1; overflow-y: auto; min-height: 400px;">
                            @foreach (var item in FilteredImageUrls)
                            {
                                <div class="d-flex flex-column align-items-center" style="width: 100px;">
                                    <img src="/images/@item" 
                                         class="img-thumbnail mb-1" 
                                         style="width: 100px; height: 48px; cursor: pointer; border: @(LauncherDTO.Icon == item ? "2px solid #007bff" : "1px solid #dee2e6"); object-fit: contain;"
                                         @onclick="@(() => LauncherDTO.Icon = item)"
                                         alt="@item" />
                                    <small class="text-center" style="word-break: break-all;">@item</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <InputText id="IconUrl" class="form-control" @bind-Value="@LauncherDTO.Icon" placeholder="Enter icon web address or image path" maxlength="500" />
                        @if (!string.IsNullOrEmpty(LauncherDTO.Icon))
                        {
                            <img src="@(LauncherDTO.Icon.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? LauncherDTO.Icon : $"/images/{LauncherDTO.Icon}")" 
                                 class="mt-2 img-thumbnail" 
                                 style="width: 100px; height: 48px; object-fit: contain;"
                                 alt="Selected icon preview" />
                        }
                    }
                    <ValidationMessage For="@(() => LauncherDTO.Icon)" />
                </div>
            </div>
            <div class="col-3">
                <div class="form-group">
                    <label for="Name">Name: <span class="text-muted">(n)</span></label> <i class="text-danger fa">*</i>
                    <InputText accesskey="n" id="Name" class="form-control" @bind-Value="@LauncherDTO.Name" placeholder="Enter Name">
                    </InputText>
                    <ValidationMessage For="@(() => LauncherDTO.Name)" />
                </div>
                <div class="form-group">
                    <label for="CategoryId">Primary Category: <span class="text-muted">(p)</span></label> <i class="text-danger fa">*</i>
                    <InputSelect accesskey="p" id="category" class="form-select" @bind-Value="@LauncherDTO.CategoryId">
                        @foreach (var category in _categories)
                        {
                            <option value="@category.Id">@category.CategoryName</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => LauncherDTO.CategoryId)" />
                </div>
                
                <div class="form-group mt-3" style="display: flex; flex-direction: column; flex-grow: 1;">
                    <label>Additional Categories:</label>
                    <div class="border p-2" style="flex-grow: 1; overflow-y: auto; min-height: 400px;">
                        @foreach (var category in _categories.Where(c => c.Id != LauncherDTO.CategoryId))
                        {
                            <div class="form-check">
                                <label class="form-check-label compact-checkbox-label" style="display:flex; align-items:center; gap:0.5rem;">
                                    <input class="compact-checkbox native-checkbox" 
                                        type="checkbox" 
                                        id="category-@category.Id" 
                                        checked="@(SelectedCategoryIds.Contains(category.Id))" 
                                        @onchange="@(e => CategoryCheckboxChanged(category.Id, e))" />
                                    <span class="custom-checkbox" aria-hidden="true"></span>
                                    <span>@category.CategoryName</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-3">
                <div class="form-group">
                    <label for="CommandLine">Command Line: <span class="text-muted">(1)</span></label>
                    <InputTextArea accesskey="1" rows="4" id="CommandLine" class="form-control" @bind-Value="@LauncherDTO.CommandLine"
                        placeholder="Enter Command Line"></InputTextArea>
                    <ValidationMessage For="@(() => LauncherDTO.CommandLine)" />
                </div>
                <div class="form-group">
                    <label for="WorkingDirectory">Working Directory: <span class="text-muted">(w)</span></label>
                    <InputTextArea accesskey="w" rows="3" id="WorkingDirectory" class="form-control" @bind-Value="@LauncherDTO.WorkingDirectory"
                        placeholder="Enter Working Directory"></InputTextArea>
                    <ValidationMessage For="@(() => LauncherDTO.WorkingDirectory)" />
                </div>
                <div class="form-group">
                    <label for="Arguments">Arguments: <span class="text-muted">(g)</span></label>
                    <InputTextArea accesskey="g" rows="3" id="Arguments" class="form-control" @bind-Value="@LauncherDTO.Arguments"
                        placeholder="Enter Arguments"></InputTextArea>
                    <ValidationMessage For="@(() => LauncherDTO.Arguments)" />
                </div>
                <div class="form-group">
                    <label for="SortOrder">Sort Order: <span class="text-muted">(s)</span></label>
                    <InputNumber accesskey="s" id="SortOrder" class="form-control" @bind-Value="@LauncherDTO.SortOrder"
                        placeholder="Enter Sort Order"></InputNumber>
                    <ValidationMessage For="@(() => LauncherDTO.SortOrder)" />
                </div>
                <div class="form-group">
                    <div class="form-check mt-2 d-flex align-items-center">
                        <button type="button"
                                id="Favorite"
                                class="btn btn-outline-primary favorite-toggle"
                                title="Favourite (6)"
                                aria-pressed="@LauncherDTO.Favourite"
                                aria-label="Toggle favourite"
                                @onclick="ToggleFavourite">
                            @if (LauncherDTO.Favourite)
                            {
                                <i class="bi bi-check-lg" aria-hidden="true"></i>
                            }
                        </button>
                        <label class="form-check-label ms-2 favorite-label" style="margin-bottom: 0;"
                               @onclick="ToggleFavourite">
                            Mark as Favourite <span class="text-muted">(6)</span>
                        </label>
                    </div>
                    <ValidationMessage For="@(() => LauncherDTO.Favourite)" />
                    <div class="d-flex flex-column mt-3">
                        @if (ModalInstance != null)
                        {
                            <button type='button' accesskey="2" class="btn btn-lg btn-outline-primary mb-2" @onclick="@Close">Cancel (2)</button>
                        }
                        else
                        {
                            <button type='button' accesskey="3" class="btn btn-lg btn-outline-secondary mb-2" @onclick="GoBack">
                                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                                <span class="ms-2">Back (3)</span>
                            </button>
                        }
                        <button @TaskRunning accesskey="4" type="submit" class="btn btn-lg btn-primary mb-2">Save Record (4)</button>
                    </div>
                </div>
                <!-- Computer ID field hidden as only one computer is used -->
            </div>
        </div>
        <!-- Action buttons moved to third column under Favourite checkbox -->
    </EditForm>
</div>

