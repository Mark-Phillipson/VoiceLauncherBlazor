@page "/android-voice-access-editing-cheatsheet"

<PageTitle>Android Voice Access Commands</PageTitle>

<div class="voice-access-sheet container-fluid py-3">
    <section class="voice-access-hero mb-3" aria-labelledby="voiceAccessTitle">
        <div class="d-flex flex-column flex-lg-row gap-3 align-items-lg-end justify-content-between">
            <div>
                <h2 id="voiceAccessTitle" class="mb-1">Android Voice Access Commands</h2>
                <p class="text-muted mb-0">Search across all command categories and quickly find the exact phrase you need.</p>
            </div>
            <div class="voice-access-meta">
                <a class="badge meta-chip source-link"
                   href="https://appt.org/en/docs/android/features/voice-access#text-editing"
                   target="_blank"
                   rel="noopener noreferrer">Source: Appt Voice Access docs</a>
                <span class="badge meta-chip">Categories: @FilteredGroups.Count</span>
                <span class="badge meta-chip">Commands: @FilteredCount</span>
            </div>
        </div>
    </section>

    <section class="voice-access-search card border-0 shadow-sm mb-4" aria-label="Search commands">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-lg-9">
                    <label class="form-label fw-semibold" for="voiceAccessSearchInput">Search command phrases or descriptions</label>
                    <input id="voiceAccessSearchInput"
                           class="form-control form-control-lg"
                           type="text"
                           placeholder="Examples: swipe, magnify, select, timer, Wi-Fi (Alt+1)"
                           aria-label="Search Voice Access commands"
                              @ref="searchInput"
                           @bind="SearchTerm"
                           @bind:event="oninput"
                           accesskey="1" />
                        <small class="text-muted">Alt+1 to focus search in supported browsers.</small>
                </div>
                <div class="col-12 col-lg-3 d-grid">
                    <label class="form-label fw-semibold invisible d-none d-lg-block" aria-hidden="true">Clear search</label>
                    <button type="button"
                            class="btn btn-outline-info btn-lg search-clear-button"
                            @onclick="ClearSearch"
                            disabled="@string.IsNullOrWhiteSpace(SearchTerm)"
                            accesskey="2"
                            title="Clear search (Alt+2)">Clear (Alt+2)</button>
                    <small class="text-muted invisible d-none d-lg-block" aria-hidden="true">Alt+2 to clear search in supported browsers.</small>
                </div>
            </div>
            <div class="mt-3 search-status" role="status" aria-live="polite">@StatusText</div>
        </div>
    </section>

    @if (FilteredGroups.Count == 0)
    {
        <div class="alert empty-state" role="alert">
            No commands match <strong>@SearchTerm</strong>. Try a broader term.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var group in FilteredGroups)
            {
                <div class="col-12 col-xxl-6">
                    <section class="command-category card border-0 shadow-sm h-100" aria-labelledby="@group.SectionId">
                        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <h3 class="h6 mb-0" id="@group.SectionId">@group.Section</h3>
                            <span class="category-chip">@group.Category</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th scope="col" class="command-col">Command</th>
                                        <th scope="col">What it does</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var command in group.Commands)
                                    {
                                        <tr>
                                            <td class="command-cell">@command.Phrase</td>
                                            <td>@command.Description</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>
            }
        </div>
    }
</div>
