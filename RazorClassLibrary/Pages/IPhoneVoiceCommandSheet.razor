@page "/iphone-voice-commands"
@namespace RazorClassLibrary.Pages

<h1 class="mt-3">iPhone Voice Control Cheat Sheet</h1>

<section class="cheatsheet">
    <h3>Navigation & Apps / App Switching / Touch & Gestures</h3>
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>🔹 Navigation & Apps</th>
                    <th>🔹 App Switching</th>
                    <th>🔹 Touch & Gestures</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Go home</td><td>Open [app name]</td><td>Tap [text]</td></tr>
                <tr><td>Open [app]</td><td>Switch to [app]</td><td>Tap [number]</td></tr>
                <tr><td>Go back</td><td>Show App Switcher</td><td>Long press</td></tr>
                <tr><td>Control Center</td><td>Swipe up + hold</td><td>Double tap</td></tr>
                <tr><td>Notifications</td><td>Tap [number]</td><td>Swipe any direction</td></tr>
            </tbody>
        </table>
    </div>

    <h3>Precision / Scrolling / Device</h3>
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr><th>🔹 Precision</th><th>🔹 Scrolling</th><th>🔹 Device</th></tr>
            </thead>
            <tbody>
                <tr><td>Show numbers</td><td>Scroll up/down</td><td>Volume up/down</td></tr>
                <tr><td>Show grid</td><td>Page up/down</td><td>Mute</td></tr>
                <tr><td>Hide numbers</td><td>Scroll top/bottom</td><td>Lock screen</td></tr>
                <tr><td>Hide grid</td><td></td><td>Screenshot</td></tr>
            </tbody>
        </table>
    </div>

    <h3>Text Selection / Text Editing / Cursor</h3>
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr><th>🔹 Text Selection</th><th>🔹 Text Editing</th><th>🔹 Cursor</th></tr>
            </thead>
            <tbody>
                <tr><td>Select [word]</td><td>Delete that</td><td>Move left/right</td></tr>
                <tr><td>Select next</td><td>Delete word</td><td>Move up/down</td></tr>
                <tr><td>Select previous</td><td>Delete sentence</td><td>Beginning / End</td></tr>
                <tr><td>Select sentence</td><td>Clear all</td><td></td></tr>
                <tr><td>Select all</td><td>Replace X with Y</td><td></td></tr>
            </tbody>
        </table>
    </div>

    <h3>Formatting / Undo/Redo / Dictation</h3>
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr><th>🔹 Formatting</th><th>🔹 Undo/Redo</th><th>🔹 Dictation</th></tr>
            </thead>
            <tbody>
                <tr><td>Capitalize</td><td>Undo</td><td>Start dictation</td></tr>
                <tr><td>Uppercase</td><td>Redo</td><td>Stop dictation</td></tr>
                <tr><td>Lowercase</td><td></td><td>Spell that</td></tr>
                <tr><td></td><td></td><td>New line</td></tr>
                <tr><td></td><td></td><td>New paragraph</td></tr>
            </tbody>
        </table>
    </div>

    <h3>Speed Tips / Custom Commands</h3>
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr><th>🔹 Speed Tips</th><th>🔹 Custom Commands</th></tr>
            </thead>
            <tbody>
                <tr><td>Use short commands</td><td>"Lefty" → Swipe left</td></tr>
                <tr><td>Use numbers overlay</td><td>"Righty" → Swipe right</td></tr>
                <tr><td>Use grid for precision</td><td>"Upy" → Swipe up</td></tr>
                <tr><td>Combine actions</td><td>"Downy" → Swipe down</td></tr>
                <tr><td></td><td>"Switcher" → App Switcher</td></tr>
            </tbody>
        </table>
    </div>

    <h3>Help</h3>
    <p>Say: "Show commands"</p>
    <p>Settings → Accessibility → Voice Control → Commands</p>
</section>
